{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "composite": true,
    "outDir": "./dist/shared",
    "rootDir": "./src/shared"
  },
  "include": ["src/shared/**/*.ts"],
  "exclude": ["node_modules"]
}
