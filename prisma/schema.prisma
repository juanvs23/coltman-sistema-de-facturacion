generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  editable    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // bcrypt hash
  fullName  String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales            Sale[]
  cancelledSales   Sale[]          @relation("CancelledSale")
  movements        CashMovement[]
  closedRegisters  CashRegister[]
  rateChanges      UsdRate[]
}

model Permission {
  id          String   @id @default(uuid())
  handler     String   @unique
  description String?
  category    String   @default("general")

  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─── Customers (RIF / datos fiscales) ────────────────────────

model Customer {
  id        String   @id @default(uuid())
  taxId     String   @unique // Identificador fiscal: RIF (VE), NIT (CO), RFC (MX), RUC (EC)
  name      String
  address   String?
  phone     String?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     Sale[]
}

// ─── Products & Inventory ────────────────────────────────────

enum ProductType {
  PRODUCT       // Producto físico con inventario
  SERVICE       // Servicio sin control de inventario
  COMBO         // Paquete de productos/servicios
}

model Product {
  id          String      @id @default(uuid())
  code        String      @unique // SKU / código de barras
  name        String
  description String?
  type        ProductType @default(PRODUCT)
  price       Float       @default(0) // Precio calculado en moneda local (priceUsd * tasa del día)
  priceUsd    Float       // Precio referencial en USD (valor primario)
  cost        Float?      // Costo (para margen de ganancia)
  stock       Int         @default(0)
  image       String?     // Ruta de imagen del producto
  active      Boolean     @default(true)
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  saleItems   SaleItem[]
  taxes       ProductTax[]
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  color    String?   // Para badges y organización visual
  products Product[]
}

// ─── Taxes (impuestos configurables) ──────────────────────────

model Tax {
  id          String       @id @default(uuid())
  name        String       @unique // Ej: "IVA 16%", "IVA Reducido 8%"
  rate        Float        // Porcentaje, ej: 16.0
  description String?
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  products    ProductTax[]
}

model ProductTax {
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  taxId     String
  tax       Tax     @relation(fields: [taxId], references: [id], onDelete: Cascade)

  @@id([productId, taxId])
}

// ─── Sales & Transactions ────────────────────────────────────

enum SaleStatus {
  ACTIVE        // En curso (carrito abierto)
  COMPLETED     // Cobrada exitosamente
  CANCELLED     // Anulada
  REFUNDED      // Reembolsada
}

enum DocumentType {
  FACTURA       // Factura fiscal — requiere cliente
  TICKET        // Ticket consumidor final — sin datos de cliente
}

enum PaymentMethod {
  CASH          // Efectivo
  TRANSFER      // Transferencia/Pago Móvil
  DEBIT_CARD    // Débito
  CREDIT_CARD   // Crédito
  DIVISA        // Divisas (USD, EUR)
  MIXED         // Mixto
}

model Sale {
  id              String       @id @default(uuid())
  receiptNumber   Int          @unique // Número de factura correlativo
  documentType    DocumentType @default(TICKET)
  status          SaleStatus   @default(ACTIVE)
  subtotal        Float        // Suma de items sin IVA
  taxTotal        Float        // Suma de IVA
  discount        Float        @default(0)
  total           Float        // Monto final
  usdRate         Float?       // Tasa del dólar al momento de la venta
  notes           String?
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  createdAt       DateTime     @default(now())
  cancelledAt     DateTime?
  cancelledById   String?
  cancelledBy     User?        @relation("CancelledSale", fields: [cancelledById], references: [id])

  items SaleItem[]
  payments PaymentEntry[]
  customerId   String?
  customer     Customer?   @relation(fields: [customerId], references: [id])
}

model SaleItem {
  id           String  @id @default(uuid())
  quantity     Int
  price        Float   // Precio unitario en moneda local al momento de la venta
  priceUsd     Float?  // Precio unitario en USD al momento de la venta
  discount     Float   @default(0) // Descuento por línea en USD
  subtotal     Float   // (quantity * price) - discount
  taxRate      Float   @default(16.0) // Tasa combinada de impuestos
  taxAmount    Float   // Suma total de impuestos
  taxBreakdown String? // JSON con desglose: [{"taxId":"...","name":"IVA 16%","rate":16,"amount":1.28}]
  total        Float   // subtotal + taxAmount
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  saleId       String
  sale         Sale    @relation(fields: [saleId], references: [id])

  @@index([saleId])
}

model PaymentEntry {
  id        String  @id @default(uuid())
  method    String  // CASH, TRANSFER, DEBIT_CARD, CREDIT_CARD, DIVISA
  amountBs  Float   // Monto en bolívares
  reference String? // Número de referencia (transferencia, último 4 dígitos)
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

// ─── Cash Register (Arqueo de Caja) ──────────────────────────

enum CashMovementType {
  OPENING       // Apertura de caja
  INCOME       // Ingreso extra
  EXPENSE      // Gasto
  WITHDRAWAL   // Retiro
  CLOSING      // Cierre de caja
}

model CashRegister {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  openingBalance Float @default(0) // Saldo inicial
  closingBalance Float? // Saldo al cierre
  closedAt    DateTime?
  closedById  String?
  closedBy    User?    @relation(fields: [closedById], references: [id])
  createdAt   DateTime @default(now())

  movements CashMovement[]
}

model CashMovement {
  id          String            @id @default(uuid())
  type        CashMovementType
  amount      Float
  description String?
  reference   String?           // Número de referencia si aplica
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  registerId  String
  register    CashRegister      @relation(fields: [registerId], references: [id])
  saleId      String?
  createdAt   DateTime          @default(now())

  @@index([registerId])
}

// ─── Company Configuration ───────────────────────────────────

model CompanyConfig {
  id           String   @id @default("default")
  businessName String
  taxId        String?
  address      String?
  phone        String?
  email        String?
  logo         String?  // Ruta de archivo de imagen
  updatedAt    DateTime @updatedAt
}

// ─── Fiscal & Configuration ──────────────────────────────────

model FiscalConfig {
  id               String   @id @default("default")
  printerType      String   // "bixolon", "epson", "sharp", "sam4s"
  printerPort      String   // Puerto COM, USB, etc.
  printerEnabled   Boolean  @default(false)
  seniatEnabled    Boolean  @default(false)
  autoSendSeniat   Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model AppConfig {
  id                String  @id @default("default")
  country           String  @default("VE")
  currencySymbol    String  @default("Bs.")
  usdRate           Float   @default(0)
  usdRateSource     String  @default("bcv")
  usdRateId         String?
  usdAutoUpdate     Boolean @default(false)
  receiptFooter     String?
  taxRateDefault    Float   @default(16.0)
  lowStockThreshold Int     @default(10)
  darkMode          Boolean @default(false)
  inactivityTimeout Int     @default(600)
  updatedAt         DateTime @updatedAt
}

// ─── USD Rate History ───────────────────────────────────────

model UsdRate {
  id          String   @id @default(uuid())
  rate        Float
  source      String   @default("manual")
  notes       String?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}
