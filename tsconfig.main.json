{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist/main",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@main/*": ["./src/main/*"],
      "@shared/*": ["./src/shared/*"],
      "@plugin-api": ["./plugin-api/src"],
      "@plugin-api/*": ["./plugin-api/src/*"]
    }
  },
  "include": ["src/main/**/*.ts", "src/shared/**/*.ts", "plugin-api/src/**/*.ts"],
  "exclude": ["node_modules"]
}
